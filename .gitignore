@"
# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/

# Banco de dados
*.db
*.sqlite
*.sqlite3

# Variáveis de ambiente (NUNCA suba o .env)
.env

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Pytest
.pytest_cache/
.coverage
htmlcov/

# Alembic
# migrations/versions/*.py (descomente se quiser versionar migrations)
"@ | Out-File -FilePath ".gitignore" -Encoding utf8