{
  "info": {
    "name": "Raízes do Nordeste API - Testes Completos",
    "description": "Coleção de testes da API - Projeto Multidisciplinar",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "pedido_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "T01 - Login Cliente Válido",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token retornado', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.access_token).to.exist;",
                  "    pm.collectionVariables.set('access_token', json.access_token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ana@exemplo.com\",\n  \"senha\": \"Cliente@123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "T02 - Login com Senha Inválida (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('Erro padrão retornado', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.error).to.eql('CREDENCIAIS_INVALIDAS');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ana@exemplo.com\",\n  \"senha\": \"SenhaErrada\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "T03 - Registrar Novo Cliente",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Usuário criado', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.id).to.exist;",
                  "    pm.expect(json.email).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Cliente Teste\",\n  \"email\": \"teste{{$timestamp}}@exemplo.com\",\n  \"senha\": \"Senha@123\",\n  \"cpf\": \"111.222.333-44\",\n  \"perfil\": \"CLIENTE\",\n  \"consentimento_lgpd\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/registrar",
              "host": ["{{base_url}}"],
              "path": ["auth", "registrar"]
            }
          }
        }
      ]
    },
    {
      "name": "Produtos",
      "item": [
        {
          "name": "T04 - Listar Produtos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Lista de produtos retornada', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.produtos).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/produtos?limit=10",
              "host": ["{{base_url}}"],
              "path": ["produtos"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "T05 - Cardápio da Unidade 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Produtos com preço retornados', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.produtos).to.be.an('array');",
                  "    if(json.produtos.length > 0) {",
                  "        pm.expect(json.produtos[0].preco).to.exist;",
                  "    }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/produtos/unidade/1",
              "host": ["{{base_url}}"],
              "path": ["produtos", "unidade", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "Pedidos",
      "item": [
        {
          "name": "T06 - Criar Pedido Válido com Canal TOTEM",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Pedido criado com canal_pedido', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.id).to.exist;",
                  "    pm.expect(json.codigo).to.exist;",
                  "    pm.expect(json.canal_pedido).to.eql('TOTEM');",
                  "    pm.expect(json.status).to.eql('AGUARDANDO_PAGAMENTO');",
                  "    pm.collectionVariables.set('pedido_id', json.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unidade_id\": 1,\n  \"canal_pedido\": \"TOTEM\",\n  \"itens\": [\n    {\"produto_id\": 1, \"quantidade\": 2},\n    {\"produto_id\": 5, \"quantidade\": 1}\n  ],\n  \"forma_pagamento\": \"PIX\",\n  \"observacao\": \"Sem cebola\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/pedidos",
              "host": ["{{base_url}}"],
              "path": ["pedidos"]
            }
          }
        },
        {
          "name": "T07 - Criar Pedido SEM Token (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unidade_id\": 1,\n  \"canal_pedido\": \"APP\",\n  \"itens\": [{\"produto_id\": 1, \"quantidade\": 1}],\n  \"forma_pagamento\": \"PIX\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/pedidos",
              "host": ["{{base_url}}"],
              "path": ["pedidos"]
            }
          }
        },
        {
          "name": "T08 - Criar Pedido SEM canal_pedido (422)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422', () => pm.response.to.have.status(422));"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unidade_id\": 1,\n  \"itens\": [{\"produto_id\": 1, \"quantidade\": 1}],\n  \"forma_pagamento\": \"PIX\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/pedidos",
              "host": ["{{base_url}}"],
              "path": ["pedidos"]
            }
          }
        },
        {
          "name": "T09 - Listar Pedidos Filtrados por Canal",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Filtro aplicado', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.filtros.canal_pedido).to.eql('TOTEM');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/pedidos?canal_pedido=TOTEM",
              "host": ["{{base_url}}"],
              "path": ["pedidos"],
              "query": [
                {
                  "key": "canal_pedido",
                  "value": "TOTEM"
                }
              ]
            }
          }
        },
        {
          "name": "T10 - Buscar Pedido por ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Pedido retornado', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.id).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/pedidos/{{pedido_id}}",
              "host": ["{{base_url}}"],
              "path": ["pedidos", "{{pedido_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Pagamentos",
      "item": [
        {
          "name": "T11 - Processar Pagamento Mock",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Pagamento processado', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.status).to.be.oneOf(['APROVADO', 'NEGADO']);",
                  "    pm.expect(json.transacao_id).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/pagamentos/processar/{{pedido_id}}",
              "host": ["{{base_url}}"],
              "path": ["pagamentos", "processar", "{{pedido_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Fidelidade",
      "item": [
        {
          "name": "T12 - Consultar Saldo de Pontos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Saldo retornado', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.saldo_pontos).to.exist;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{access_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/fidelidade/saldo",
              "host": ["{{base_url}}"],
              "path": ["fidelidade", "saldo"]
            }
          }
        }
      ]
    }
  ]
}